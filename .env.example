# Recognition provider: aws | mock
RECOGNITION_PROVIDER=mock

# AWS Rekognition (required when RECOGNITION_PROVIDER=aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Minimum match confidence (0-100). AWS recommends 97+ to reduce wrong guesses.
MIN_CONFIDENCE=97

# Top match must beat the runner-up by at least this many points.
MIN_MATCH_MARGIN=12

# Server port
PORT=3001
